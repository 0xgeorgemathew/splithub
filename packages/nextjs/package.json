{
  "name": "@se-2/nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check-types": "tsc --noEmit --incremental",
    "dev": "next dev",
    "dev:trigger": "npx trigger.dev@latest dev",
    "deploy:trigger": "npx trigger.dev@latest deploy",
    "format": "prettier --write . '!(node_modules|.next|contracts)/**/*'",
    "ipfs": "NEXT_PUBLIC_IPFS_BUILD=true next build",
    "lint": "eslint .",
    "serve": "next start",
    "start": "next dev",
    "vercel": "vercel --build-env VERCEL_TELEMETRY_DISABLED=1",
    "vercel:login": "vercel login",
    "vercel:yolo": "vercel --build-env NEXT_PUBLIC_IGNORE_BUILD_ERROR=true --build-env VERCEL_TELEMETRY_DISABLED=1"
  },
  "dependencies": {
    "@arx-research/libhalo": "^1.15.0",
    "@heroicons/react": "~2.1.5",
    "@privy-io/react-auth": "^3.8.1",
    "@privy-io/wagmi": "^2.1.0",
    "@scaffold-ui/components": "^0.1.3",
    "@scaffold-ui/hooks": "^0.1.2",
    "@serwist/next": "^9.2.3",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.11.0",
    "@solana-program/token": "^0.10.0",
    "@solana/kit": "^6.0.1",
    "@tanstack/react-query": "~5.59.15",
    "@trigger.dev/sdk": "^4.4.3",
    "daisyui": "5.0.9",
    "lucide-react": "^0.555.0",
    "next": "16.1.6",
    "next-nprogress-bar": "~2.3.13",
    "next-themes": "~0.4.6",
    "qrcode.react": "~4.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "~2.4.0",
    "react-onesignal": "^3.4.0",
    "serwist": "^9.2.3",
    "usehooks-ts": "~3.1.0",
    "viem": "2.34.0",
    "wagmi": "2.16.4",
    "zustand": "~5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.0.15",
    "@trigger.dev/build": "^4.4.3",
    "@trivago/prettier-plugin-sort-imports": "~4.3.0",
    "@types/node": "~18.19.50",
    "@types/react": "19.2.14",
    "abitype": "1.0.6",
    "autoprefixer": "~10.4.20",
    "eslint": "~9.23.0",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "~10.1.1",
    "eslint-plugin-prettier": "~5.2.4",
    "postcss": "~8.4.45",
    "prettier": "~3.5.3",
    "tailwindcss": "4.1.3",
    "type-fest": "~4.26.1",
    "typescript": "~5.8.2"
  },
  "resolutions": {
    "@types/react": "19.2.14"
  }
}
