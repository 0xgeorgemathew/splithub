# Next.js Environment Variables
# Copy to .env.local and fill in values

# Supabase - https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Privy Auth - https://dashboard.privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id

# Relayer (server-side only - pays gas for gasless transactions)
RELAYER_PRIVATE_KEY=0x...

# OneSignal Push Notifications - https://onesignal.com/
NEXT_PUBLIC_ONESIGNAL_APP_ID=your_app_id
ONESIGNAL_REST_API_KEY=your_rest_api_key  # server-side only

# App URL for deep links and OAuth callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000
